{
  "name": "@threadlens/api",
  "version": "0.3.0",
  "description": "Fastify API gateway for ThreadLens",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude dist --exclude dist-electron --exclude ../../packages/shared-contracts/dist src/cli.ts",
    "build": "pnpm --filter @threadlens/shared-contracts build && tsc -p tsconfig.json",
    "bundle:desktop": "pnpm --filter @threadlens/shared-contracts build && node -e \"require('node:fs').rmSync('dist-electron',{recursive:true,force:true})\" && esbuild src/cli.ts --bundle --platform=node --format=cjs --target=node22 --define:import.meta.url='\"file:///threadlens/api-cli.mjs\"' --outfile=dist-electron/server.cjs",
    "start": "node dist/cli.js",
    "test": "pnpm --filter @threadlens/shared-contracts build && vitest run --fileParallelism=false",
    "lint": "pnpm --filter @threadlens/shared-contracts build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@threadlens/shared-contracts": "workspace:*",
    "fastify": "^5.8.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "esbuild": "0.28.0",
    "tsx": "4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
