{
  "name": "@provider-surface/api",
  "version": "0.1.0",
  "description": "Fastify API gateway for Provider Observatory",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "bundle:desktop": "rm -rf dist-electron && esbuild src/cli.ts --bundle --platform=node --format=cjs --target=node20 --define:import.meta.url='\"file:///provider-surface/api-cli.mjs\"' --outfile=dist-electron/server.cjs",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@provider-surface/shared-contracts": "workspace:*",
    "@fastify/cors": "^10.1.0",
    "fastify": "^5.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
