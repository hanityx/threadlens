{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Mission Control",
  "version": "0.1.0",
  "identifier": "com.developer.codexmissioncontrol",
  "build": {
    "beforeDevCommand": "cd ../.. && pnpm dev",
    "beforeBuildCommand": "cd ../.. && pnpm -r build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Mission Control",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
