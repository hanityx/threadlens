{
  "name": "@threadlens/tui",
  "version": "0.3.0",
  "description": "Terminal workbench for ThreadLens",
  "license": "MIT",
  "type": "module",
  "bin": {
    "threadlens-tui": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.tsx",
    "build": "pnpm --filter @threadlens/shared-contracts build && tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "pnpm --filter @threadlens/shared-contracts build && tsx --test test/*.test.ts",
    "lint": "pnpm --filter @threadlens/shared-contracts build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@threadlens/shared-contracts": "workspace:*",
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "19.2.14",
    "tsx": "4.21.0",
    "typescript": "^6.0.3"
  }
}
