{
  "name": "@threadlens/web",
  "version": "0.3.0",
  "description": "React workbench UI for ThreadLens",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "storybook": "storybook dev --ci --port 6006",
    "build-storybook": "storybook build",
    "preview": "vite preview",
    "test": "vitest run -c vitest.config.ts",
    "test:coverage": "vitest run -c vitest.config.ts --coverage",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:live": "playwright test -c playwright.live.config.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@threadlens/shared-contracts": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "agentation": "^3.0.2",
    "storybook": "10.3.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
