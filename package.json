{
  "name": "threadlens-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first observability dashboard for AI threads and sessions",
  "license": "MIT",
  "homepage": "https://github.com/threadlens/threadlens",
  "bugs": {
    "url": "https://github.com/threadlens/threadlens/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/threadlens/threadlens.git"
  },
  "keywords": [
    "electron",
    "observability",
    "ai",
    "providers",
    "sessions",
    "local-first"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.27.4",
      "fastify": "^5.8.2",
      "yauzl": "^3.2.1"
    }
  },
  "scripts": {
    "dev:api": "pnpm --filter @threadlens/shared-contracts build && pnpm --filter @threadlens/api dev",
    "dev:tui": "pnpm --filter @threadlens/tui dev",
    "dev:web": "pnpm --filter @threadlens/web dev",
    "dev:desktop": "ELECTRON_RENDERER_URL=http://127.0.0.1:5174 pnpm --filter @threadlens/desktop-electron dev",
    "dev": "pnpm --filter @threadlens/shared-contracts build && pnpm -r --parallel --filter @threadlens/api --filter @threadlens/web dev",
    "build": "pnpm --filter @threadlens/shared-contracts build && pnpm --filter @threadlens/api build && pnpm --filter @threadlens/web build",
    "build:tui": "pnpm --filter @threadlens/tui build",
    "start:tui": "pnpm --filter @threadlens/tui start",
    "build:desktop": "pnpm --filter @threadlens/shared-contracts build && pnpm --filter @threadlens/web build && pnpm --filter @threadlens/api bundle:desktop && pnpm --filter @threadlens/desktop-electron build",
    "package:desktop": "pnpm build:desktop && pnpm --filter @threadlens/desktop-electron dist:mac",
    "package:desktop:dir": "pnpm build:desktop && pnpm --filter @threadlens/desktop-electron dist:dir",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
